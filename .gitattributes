# Ensure consistent LF line endings for source and freeze cache files
*.R       text eol=lf
*.qmd     text eol=lf
*.json    text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.md      text eol=lf
*.css     text eol=lf

# Treat binary files as binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.svg     binary
*.min.js  binary
*.min.css binary
